    </mxGraphModel>
  </diagram>
  <diagram id="CV6bk40MJ1-PnfB5TAIw" name="Mermaid UML sequence diagram">
    <mxGraphModel dx="1151" dy="832" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
